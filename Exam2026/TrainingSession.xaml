<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Exam2026"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="Exam2026.TrainingSession"
        mc:Ignorable="d"
        Title="TrainingSession" Height="450" Width="800">
    <Grid>
        <TextBlock 
           Text="Add New Training Session"
           FontFamily="Noto Sans" FontSize="16" FontWeight="Bold"
           Margin="332,10,266,393"/>
        <Label Content="Date" HorizontalAlignment="Left" Margin="59,74,0,0" VerticalAlignment="Top"/>
        <Label Content="Start Time                " HorizontalAlignment="Left" Margin="59,117,0,0" VerticalAlignment="Top"/>
        <Label Content="Session Type                " HorizontalAlignment="Left" Margin="59,159,0,0" VerticalAlignment="Top"/>
        <Label Content="Duration (Mins)                " HorizontalAlignment="Left" Margin="59,217,0,0" VerticalAlignment="Top"/>
        <Label Content="Coach Notes               " HorizontalAlignment="Left" Margin="59,262,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left" Margin="158,366,0,0" VerticalAlignment="Top" Background="WhiteSmoke" BorderBrush="White" Foreground="#FF1C4C8C" Click="btnCancel_Click"/>
        <Button x:Name="btnSave" Content="Save" HorizontalAlignment="Left" Margin="311,366,0,0" VerticalAlignment="Top" Background="#FF3596B7" BorderBrush="White" Foreground="White" Width="274" Click="btnSave_Click"/>
        <DatePicker x:Name="datePick" HorizontalAlignment="Left" Margin="195,74,0,0" VerticalAlignment="Top" Height="24" Width="493"/>
        <materialDesign:TimePicker x:Name="timePick" HorizontalAlignment="Left" Margin="195,113,0,0" VerticalAlignment="Top" Height="31" Width="493"/>
        <ComboBox x:Name="Type" HorizontalAlignment="Left" Margin="195,163,0,0" VerticalAlignment="Top" Width="493"/>
        <TextBox x:Name="tbxNotes" HorizontalAlignment="Left" Margin="222,274,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="440" Height="75"/>
        <materialDesign:NumericUpDown x:Name="Duration" HorizontalAlignment="Left" Margin="199,217,0,0" VerticalAlignment="Top" Height="24" Width="489"/>
    </Grid>
</Window>
